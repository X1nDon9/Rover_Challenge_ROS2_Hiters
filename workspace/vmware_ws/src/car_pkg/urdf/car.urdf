<?xml version="1.0"?>
<robot name="ros2_car">

  <!-- ==================== 基础足迹坐标系 (base_footprint) ==================== -->
  <!-- 这是一个虚拟坐标系，通常位于机器人正下方的地面上 -->
  <!-- 它的作用是将机器人的高度投影到地面，方便导航算法计算 -->
  <link name="base_footprint"/>
  
  <!-- ==================== 基础链接 (base_link) ==================== -->
  <!-- 机器人的物理底盘中心 -->
  <!-- joint 定义了底盘相对于地面的位置：向上抬起 0.043m -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.043" rpy="0 0 0"/>
  </joint>
  <link name="base_link">
    <!-- 底盘外观：蓝色圆柱体 (半径0.092m, 厚度3mm) -->
    <visual>
      <geometry>
        <cylinder radius="0.092" length="0.003"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- ==================== 驱动轮 (黑色) ==================== -->
  
  <!-- 左驱动轮 -->
  <!-- joint type="continuous" 表示这是一个可以无限旋转的关节 (轮子) -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- 
      xyz: 相对于底盘中心的位置
        x=-0.03 (靠后)
        y=0.07 (左侧)
        z=-0.015 (向下，使得轮子着地)
      rpy="1.5708 0 0": 绕X轴旋转90度，将直立的圆柱体横放变成轮子
      axis xyz="0 0 1": 轮子绕其自身的Z轴旋转 (因为rpy旋转了坐标系，现在的Z轴即车轴方向)
    -->
    <origin xyz="-0.03 0.07 -0.015" rpy="1.5708 0 0"/> 
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- 右驱动轮 -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- y=-0.07 (右侧)，其它参数同左轮 -->
    <origin xyz="-0.03 -0.07 -0.015" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.025"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ==================== 万向轮 (黄色) ==================== -->
  <!-- 位于车头，用于支撑底盘 -->
  <!-- 这里为了简化仿真，使用了 fixed 关节，实际物理中它应该可以自由旋转 -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- x=0.07 (前移), z=-0.021 (根据球半径调整高度以接触地面) -->
    <origin xyz="0.07 0 -0.021" rpy="0 0 0"/>
  </joint>
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.023"/>
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ==================== 激光雷达 (laser_link) ==================== -->
  <!-- 包含了雷达本体和下方的白色支撑柱 -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <!-- 
      位置计算:
      支撑柱位于 x=0.057
      高度 z=0.0745 是支撑柱高度 + 安装位置的结果
    -->
    <origin xyz="0.057 0 0.0745" rpy="0 0 0"/>
  </joint>
  <link name="laser_link">
    <!-- 激光雷达黑色圆柱体本体 -->
    <visual>
      <geometry>
        <cylinder radius="0.037" length="0.039"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <!-- 支撑柱 (由于整合进了同一个link，需要反向偏移坐标以正确显示在下方) -->
    <!-- z=-0.0365: 向下移动，连接到底盘 -->
    <visual>
      <origin xyz="0 0 -0.0365" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.008" length="0.073"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

</robot>